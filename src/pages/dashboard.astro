---
import Layout from '../layouts/Layout.astro';
import dbConnect from '../lib/db';
import Invite from '../models/Invite';
import Rsvp from '../models/Rsvp';
import User from '../models/User';
import { getSession } from '../lib/auth';
import { Calendar, Users, Eye, Edit3, Trash2, LogOut, ExternalLink } from 'lucide-react';

export const prerender = false;

const session = getSession(Astro.cookies);
if (!session) {
  return Astro.redirect('/login');
}

await dbConnect();
const user = await User.findById(session.userId);
if (!user) {
  // Session cookie might be invalid/user deleted
  Astro.cookies.delete('token', { path: '/' });
  return Astro.redirect('/login');
}

// Fetch user's invitations
const invites = await Invite.find({ creatorId: session.userId }).sort({ createdAt: -1 });

// For each invite, fetch RSVPs
const invitesWithRsvps = await Promise.all(
  invites.map(async (invite) => {
    const rsvps = await Rsvp.find({ inviteId: invite._id }).sort({ createdAt: -1 });
    const totalAttendingGuests = rsvps.reduce(
      (acc, curr) => (curr.status === 'attending' ? acc + curr.guestCount : acc),
      0
    );
    const totalDeclinedCount = rsvps.filter((r) => r.status === 'declined').length;
    
    // Map template labels
    let templateName = 'Custom';
    let editPath = `/templates/minimalist-wedding?id=${invite._id}`;
    if (invite.templateId === 'minimalist-wedding') {
      templateName = 'Minimalist Wedding';
      editPath = `/templates/minimalist-wedding?id=${invite._id}`;
    } else if (invite.templateId === 'neon-mixer') {
      templateName = 'Neon Mixer';
      editPath = `/templates/neon-mixer?id=${invite._id}`;
    } else if (invite.templateId === 'corporate-gala') {
      templateName = 'Corporate Gala';
      editPath = `/templates/corporate-gala?id=${invite._id}`;
    }

    return {
      invite,
      templateName,
      editPath,
      rsvps,
      totalAttendingGuests,
      totalDeclinedCount,
    };
  })
);
---

<Layout title="thEnvites - Creator Dashboard">
  <div class="min-h-[85vh] py-16 px-5 md:px-margin-desktop max-w-360 mx-auto w-full">
    
    {/* Dashboard Header */}
    <div class="flex justify-center items-center gap-6 border-b border-border-surgical pb-12 mb-16">
        <h1 class="font-headline text-4xl md:text-5xl font-bold tracking-tight text-on-background">
          Welcome back, {user.email.split('@')[0]}
        </h1>
    </div>

    {invitesWithRsvps.length === 0 ? (
      <div class="border border-dashed border-border-surgical p-16 text-center max-w-2xl mx-auto space-y-8">
        <Users className="w-12 h-12 text-on-surface-variant mx-auto font-light" strokeWidth={1} />
        <div>
          <h2 class="font-headline text-2xl font-bold mb-2">No active envites found</h2>
          <p class="font-body text-base text-on-surface-variant max-w-md mx-auto">
            Create and deploy your first premium digital invitation to begin tracking RSVPs and guest lists.
          </p>
        </div>
        <a
          href="/templates"
          class="inline-block bg-on-background text-background px-10 py-4 font-mono text-xs font-bold uppercase tracking-widest hover:invert transition-all"
        >
          Select a Template
        </a>
      </div>
    ) : (
      <div class="space-y-12">
        {invitesWithRsvps.map(({ invite, templateName, editPath, rsvps, totalAttendingGuests, totalDeclinedCount }) => (
          <div class="border border-border-surgical bg-background hover:border-on-surface-variant transition-colors flex flex-col overflow-hidden invite-card">
            
            {/* Card Header Info */}
            <div class="grid grid-cols-1 lg:grid-cols-12 border-b border-border-surgical p-8 gap-8 items-center">
              <div class="lg:col-span-4 space-y-2">
                <span class="font-mono text-[9px] uppercase tracking-widest border border-border-surgical px-3 py-1 rounded-full text-on-surface-variant inline-block">
                  {templateName}
                </span>
                <h2 class="font-headline text-2xl font-bold text-on-surface">{invite.title}</h2>
                <p class="font-body text-xs text-on-surface-variant">Host: {invite.hostName || 'Not Specified'}</p>
              </div>

              <div class="lg:col-span-4 grid grid-cols-2 md:grid-cols-3 gap-6">
                <div>
                  <span class="font-mono text-[9px] uppercase tracking-widest text-on-surface-variant block mb-1">Date</span>
                  <p class="font-mono text-xs text-on-surface font-semibold flex items-center gap-1.5">
                    <Calendar className="w-3.5 h-3.5 text-on-surface-variant" />
                    {invite.eventDate || 'TBD'}
                  </p>
                </div>
                <div>
                  <span class="font-mono text-[9px] uppercase tracking-widest text-on-surface-variant block mb-1">Attending</span>
                  <p class="font-mono text-xs text-on-surface font-bold">
                    {totalAttendingGuests} Guest{totalAttendingGuests !== 1 ? 's' : ''}
                  </p>
                </div>
                <div>
                  <span class="font-mono text-[9px] uppercase tracking-widest text-on-surface-variant block mb-1">Declined</span>
                  <p class="font-mono text-xs text-on-surface-variant font-semibold">
                    {totalDeclinedCount}
                  </p>
                </div>
              </div>

              <div class="lg:col-span-4 flex flex-wrap gap-3 lg:justify-end">
                <a
                  href={`/invites/${invite._id}`}
                  target="_blank"
                  class="flex items-center gap-2 border border-border-surgical hover:border-on-surface px-4 py-3 font-mono text-[10px] uppercase tracking-wider font-bold text-on-surface transition-colors"
                >
                  <Eye className="w-3.5 h-3.5" />
                  View Live
                </a>
                <a
                  href={editPath}
                  class="flex items-center gap-2 border border-border-surgical hover:border-on-surface px-4 py-3 font-mono text-[10px] uppercase tracking-wider font-bold text-on-surface transition-colors"
                >
                  <Edit3 className="w-3.5 h-3.5" />
                  Edit
                </a>
                <button
                  data-id={invite._id.toString()}
                  class="delete-invite-btn flex items-center gap-2 border border-red-500/20 hover:border-red-500 text-red-500/80 hover:text-red-600 px-4 py-3 font-mono text-[10px] uppercase tracking-wider font-bold transition-all cursor-pointer"
                >
                  <Trash2 className="w-3.5 h-3.5" />
                  Delete
                </button>
              </div>
            </div>

            {/* RSVP Guest List Section */}
            <div class="p-8 bg-surface-container-low border-t border-border-surgical">
              <div class="flex items-center justify-between mb-6">
                <h3 class="font-headline text-lg font-bold">Guest List ({rsvps.length} RSVP replies)</h3>
                <button
                  class="toggle-rsvps-btn font-mono text-[10px] text-on-surface-variant hover:text-on-background uppercase tracking-widest flex items-center gap-1 cursor-pointer"
                >
                  Show/Hide Guest List
                </button>
              </div>

              <div class="rsvp-table-container transition-all duration-300 overflow-hidden max-h-100 overflow-y-auto">
                {rsvps.length === 0 ? (
                  <p class="font-body text-xs text-on-surface-variant italic py-2">No guest replies have been logged for this invite yet.</p>
                ) : (
                  <table class="w-full text-left font-body text-xs border-collapse">
                    <thead>
                      <tr class="border-b border-border-surgical text-on-surface-variant font-mono text-[10px] uppercase tracking-widest">
                        <th class="pb-3 pr-4 font-semibold">Guest Name</th>
                        <th class="pb-3 px-4 font-semibold">RSVP Status</th>
                        <th class="pb-3 px-4 font-semibold">Headcount</th>
                        <th class="pb-3 pl-4 font-semibold">Notes / Requests</th>
                      </tr>
                    </thead>
                    <tbody>
                      {rsvps.map((rsvp) => (
                        <tr class="border-b border-border-surgical/40 hover:bg-surface-container-high/20 transition-colors">
                          <td class="py-4 pr-4 font-semibold text-on-surface">{rsvp.guestName}</td>
                          <td class="py-4 px-4">
                            <span class={`font-mono text-[10px] uppercase font-bold tracking-wider px-2 py-0.5 border ${
                              rsvp.status === 'attending' 
                                ? 'text-green-600 border-green-500/20 bg-green-500/5' 
                                : 'text-red-500 border-red-500/20 bg-red-500/5'
                            }`}>
                              {rsvp.status}
                            </span>
                          </td>
                          <td class="py-4 px-4 font-mono">{rsvp.guestCount}</td>
                          <td class="py-4 pl-4 text-on-surface-variant max-w-xs truncate">{rsvp.notes || '—'}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                )}
              </div>
            </div>

          </div>
        ))}
      </div>
    )}

  </div>

  <script>
    // Logout Logic
    const logoutBtn = document.getElementById('logoutBtn');
    logoutBtn?.addEventListener('click', async () => {
      try {
        const res = await fetch('/api/auth/logout', { method: 'POST' });
        if (res.ok) {
          window.location.href = '/login';
        }
      } catch (err) {
        console.error('Logout failed:', err);
      }
    });

    // Delete Invite Logic
    const deleteBtns = document.querySelectorAll('.delete-invite-btn');
    deleteBtns.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const inviteId = btn.getAttribute('data-id');
        if (!inviteId) return;

        if (confirm('Are you sure you want to permanently delete this invitation event? This will also remove all guest RSVPs associated with it.')) {
          try {
            const res = await fetch(`/api/invites/${inviteId}`, {
              method: 'DELETE',
            });
            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              alert(`Error: ${data.error || 'Failed to delete invitation.'}`);
            }
          } catch (err) {
            console.error('Delete request failed:', err);
          }
        }
      });
    });

    // Guest List Toggle Logic
    const toggleBtns = document.querySelectorAll('.toggle-rsvps-btn');
    toggleBtns.forEach((btn) => {
      const container = btn.closest('.invite-card')?.querySelector('.rsvp-table-container') as HTMLElement;
      
      // Default to visible if rsvps exist
      btn.addEventListener('click', () => {
        if (container.style.display === 'none') {
          container.style.display = 'block';
        } else {
          container.style.display = 'none';
        }
      });
    });
  </script>
</Layout>
